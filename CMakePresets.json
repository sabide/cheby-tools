{
  "version": 3,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/macos",
      "cacheVariables": {
        "Python_EXECUTABLE": "/opt/miniconda3/bin/python",
        "CHEBY_USE_BUNDLED_TECIO": "ON"
      }
    },
    {
      "name": "adastra-bundled",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/adastra-bundled",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CHEBY_USE_BUNDLED_TECIO": "ON"
      }
    },
    {
      "name": "adastra-external-tecio",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/adastra-external",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "CHEBY_USE_BUNDLED_TECIO": "OFF",
        "CHEBY_TECIO_INCLUDE_DIR": "$env{CHEBY_TECIO_INCLUDE_DIR}",
        "CHEBY_TECIO_LIBRARY": "$env{CHEBY_TECIO_LIBRARY}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "macos",
      "configurePreset": "macos"
    },
    {
      "name": "adastra-bundled",
      "configurePreset": "adastra-bundled"
    },
    {
      "name": "adastra-external-tecio",
      "configurePreset": "adastra-external-tecio"
    }
  ]
}
